<!-- Đăng ký tư vấn -->
<section class="bg-primary text-white py-5">
    <div class="container text-center">
        <h2 class="mb-3">📞 Cần tư vấn sức khỏe?</h2>
        <p class="lead mb-4">Đội ngũ chuyên gia sẵn sàng hỗ trợ bạn 24/7</p>
        <div class="row justify-content-center">
            <div class="col-md-6">
                <form asp-action="Consultation" asp-controller="Home" method="post">
                    <div class="row g-2">
                        <div class="col-md-5">
                            <input type="text" name="FullName" class="form-control" placeholder="Họ tên" required>
                        </div>
                        <div class="col-md-5">
                            <input type="tel" name="Phone" class="form-control" placeholder="Số điện thoại" required>
                        </div>
                        <div class="col-md-2">
                            <button type="submit" class="btn btn-light w-100">Gửi</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
        <p class="mt-3">Hoặc gọi ngay: <strong class="fs-4">1900 1717</strong> (miễn phí)</p>
    </div>
</section>