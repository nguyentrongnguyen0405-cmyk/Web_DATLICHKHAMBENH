@model IEnumerable<Web_Đặt_lịch_phòng_khám.Models.Doctor>
@{
    ViewData["Title"] = "Quản lý bác sĩ";
}

<h2>Quản lý bác sĩ</h2>
<a asp-action="CreateDoctor" class="btn btn-success mb-3">+ Thêm bác sĩ mới</a>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Họ tên</th>
            <th>Email</th>
            <th>Chuyên khoa</th>
            <th>Kinh nghiệm</th>
            <th>Hành động</th>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.FullName</td>
                <td>@item.User?.Email</td>
                <td>@item.Specialty?.Name</td>
                <td>@item.ExperienceYears năm</td>
                <td>
                    <form asp-action="DeleteDoctor" method="post" onsubmit="return confirm('Bạn có chắc muốn xóa bác sĩ này?');">
                        <input type="hidden" name="id" value="@item.Id" />
                        <button type="submit" class="btn btn-danger btn-sm">Xóa</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>