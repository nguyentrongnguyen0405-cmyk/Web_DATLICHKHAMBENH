@model IEnumerable<Web_Đặt_lịch_phòng_khám.Models.Specialty>

<div class="container mt-5">
    <div class="text-center mb-5">
        <h2 class="fw-bold text-primary">DỊCH VỤ CHUYÊN KHOA</h2>
        <p class="text-muted">Vui lòng chọn chuyên khoa bạn muốn thăm khám</p>
    </div>
    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-md-4 mb-4">
                <div class="card h-100 shadow-sm border-0 transition">
                    <div class="card-body text-center">
                        <div class="icon-box mb-3">
                            <i class="fas fa-stethoscope fa-3x text-info"></i>
                        </div>
                        <h5 class="card-title fw-bold">@item.Name</h5>
                        <p class="card-text text-muted small">@item.Description</p>
                        <a asp-action="Doctors" asp-route-id="@item.Id" class="btn btn-outline-primary rounded-pill px-4">
                            Chọn bác sĩ
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>