@model Web_Đặt_lịch_phòng_khám.Models.Appointment

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="card shadow-lg border-0 rounded-3">
                <div class="card-header bg-white border-0 pt-4">
                    <h4 class="text-center fw-bold text-primary">XÁC NHẬN THÔNG TIN</h4>
                </div>
                <div class="card-body p-4">
                    <div class="alert alert-info border-0">
                        <p class="mb-1"><strong>Bác sĩ:</strong> @ViewBag.DoctorName</p>
                        <p class="mb-0"><strong>Phí khám:</strong> <span class="text-danger fw-bold">@ViewBag.Fee.ToString("N0") VNĐ</span></p>
                    </div>

                    <form asp-action="Create" method="post" class="mt-4">
                        <input type="hidden" asp-for="ScheduleId" />

                        <div class="mb-3">
                            <label class="form-label fw-bold">Email của bạn</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fas fa-envelope"></i></span>
                                <input type="email" name="email" class="form-control" placeholder="nguyen@example.com" required />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Ghi chú (Tùy chọn)</label>
                            <textarea class="form-control" rows="3" placeholder="Nhập triệu chứng hoặc yêu cầu đặc biệt..."></textarea>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary btn-lg rounded-pill shadow-sm">
                                HOÀN TẤT ĐẶT LỊCH
                            </button>
                            <a asp-action="Index" class="btn btn-link text-muted">Quay lại</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>